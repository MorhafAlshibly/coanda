{
	"name": "coanda",
	"version": "1.0.0",
	"description": "A multi-purpose backend game API originally based on a racing game",
	"repository": "https://github.com/MorhafAlshibly/coanda",
	"author": "Morhaf Alshibly",
	"license": "Apache-2.0",
	"private": false,
	"scripts": {
		"dev": "ts-node ./src/utils/run-dev.ts",
		"build": "tsc --build",
		"test": "jest --detectOpenHandles",
		"terraform-setup": "node -p \"JSON.stringify(require('config').get('terraform'))\" > ./infrastructure/terraform.tfvars.json",
		"terraform-plan": "yarn terraform-setup && terraform -chdir=infrastructure plan",
		"terraform-apply": "yarn terraform-setup && terraform -chdir=infrastructure apply -auto-approve",
		"docs": "mkdirp ./docs/src && ts-node ./docs/index.ts && redoc-cli build ./docs/src/swagger.json -o ./docs/src/index.html",
		"lint": "npx eslint ./"
	},
	"dependencies": {
		"@azure/identity": "^3.1.3",
		"@azure/keyvault-secrets": "^4.6.0",
		"config": "^3.3.9",
		"cors": "^2.8.5",
		"express": "^4.18.2",
		"helmet": "^6.0.1",
		"mongoose": "^6.9.0",
		"pino": "^8.8.0",
		"zod": "^3.20.2"
	},
	"devDependencies": {
		"@types/config": "^3.3.0",
		"@types/cors": "^2.8.13",
		"@types/express": "^4.17.15",
		"@types/jest": "^29.2.4",
		"@types/node": "^18.11.17",
		"@types/pino": "^7.0.5",
		"@types/supertest": "^2.0.12",
		"@types/swagger-jsdoc": "^6.0.1",
		"@typescript-eslint/eslint-plugin": "^5.48.0",
		"@typescript-eslint/parser": "^5.48.0",
		"concurrently": "^7.6.0",
		"dotenv": "^16.0.3",
		"eslint": "^8.31.0",
		"fdir": "^5.3.0",
		"jest": "^29.3.1",
		"mkdirp": "^2.1.3",
		"pino-pretty": "^9.1.1",
		"redoc-cli": "^0.13.17",
		"supertest": "^6.3.3",
		"swagger-jsdoc": "^6.2.7",
		"ts-jest": "^29.0.3",
		"ts-node-dev": "^2.0.0",
		"typescript": "*",
		"typescript-json-schema": "^0.55.0",
		"zod-to-json-schema": "^3.20.2"
	}
}
